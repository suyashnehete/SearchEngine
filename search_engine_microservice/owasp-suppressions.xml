<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!-- 
    This file contains suppressions for OWASP Dependency Check false positives.
    Each suppression should include a comment explaining why it's safe to suppress.
    -->
    
    <!-- Example suppression for a false positive -->
    <!--
    <suppress>
        <notes><![CDATA[
        This is a false positive because we're using a specific version that doesn't have the vulnerability.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.example/example\-lib@.*$</packageUrl>
        <cve>CVE-2021-12345</cve>
    </suppress>
    -->
    
    <!-- Suppress Spring Boot development tools vulnerabilities in development -->
    <suppress>
        <notes><![CDATA[
        Spring Boot DevTools is only used in development and not included in production builds.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework\.boot/spring\-boot\-devtools@.*$</packageUrl>
    </suppress>
    
    <!-- Suppress test dependencies vulnerabilities -->
    <suppress>
        <notes><![CDATA[
        Test dependencies are not included in production builds.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/.*@.*$</packageUrl>
        <cpe>cpe:/a:junit:junit</cpe>
    </suppress>
</suppressions>